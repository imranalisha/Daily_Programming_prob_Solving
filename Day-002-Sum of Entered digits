cin>>num;
       
        while(num!=0){
           sum= sum+num%10;  //  num%10 give the last digit only
            num= num/10;     // num/10  chops(erase)the last digit (the reminder) and provide the new number
                        //  after removing the reminder for the next loop to find the reminder again ---e.g 123  -> 12 -> 1
}

cout<<"\nthe sum the entered number is : " <<sum;
       

                     
